{
  "name": "charlemont-backend",
  "version": "1.0.0",
  "description": "CharlemontWatch incident reporting API",
  "main": "server.js",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:perf:get": "artillery run performance/get-incidents.yml",
    "test:perf:post": "artillery run performance/post-report.yml",
    "test:perf:login": "artillery run performance/login-load.yml",
    "test:perf": "npm run test:perf:get && npm run test:perf:post"
  },
  "dependencies": {
    "@sentry/node": "^10.55.0",
    "aws-sdk": "^2.1400.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "resend": "^6.12.4",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "artillery": "^2.0.32",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.2.2"
  }
}

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/charlemont

# JWT
JWT_SECRET=your-secret-key-here-change-in-production

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=charlemont-incidents
AWS_REGION=eu-west-1

# Resend Email
RESEND_API_KEY=re_your-api-key-here
RESEND_FROM_EMAIL=reports@charlemontwatch.ie
ADMIN_EMAIL=your-email@example.com

# Resend webhook (Dashboard -> Webhooks -> Add Endpoint -> <API_URL>/api/webhooks/resend,
# subscribed to email.bounced/email.complained/email.delivery_delayed) — the
# signing secret Resend shows you when the endpoint is created
RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Formal complaint recipients
TUATH_COMPLAINT_EMAIL=complaints@example.com
DCC_COMPLAINT_EMAIL=complaints@example.com

# Cloudflare Turnstile (bot protection on incident reports) — Secret Key from
# dash.cloudflare.com -> Turnstile -> add a site for this domain. Leave unset
# to skip the check (logs a warning instead of blocking submissions).
TURNSTILE_SECRET_KEY=

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Admin dashboard link used in the admin notification email — should match
# VITE_ADMIN_KEY in frontend/.env
VITE_ADMIN_KEY=change-me

# Optional — error monitoring
SENTRY_DSN=
